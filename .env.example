# Server-only. Copy to .env.local; never commit real credentials.
LINKUP_API_KEY=

# Fetcher persona. This drives Linkup research and strategist recommendations.
CONTENT_NICHE=creator economy and Instagram
CONTENT_AUDIENCE=independent creators and small brands

# Optional: comma-separated, operator-approved RSS feed URLs.
RSS_FEED_URLS=

# Optional real narration for the reel proof run. Server-side only.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional absolute iCloud/phone-sync directory used only after explicit human approval.
AGENCY_OUTPUT_DIR=
