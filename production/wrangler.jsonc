{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "instagram-content-agency",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "instagram-content-agency-prod",
      "database_id": "0431fa3b-d375-47e4-848e-ba1f6e97465e"
    }
  ],
  "vars": {
    "OPENAI_MODEL": "gpt-4.1-mini"
  }
}
